# Copy to .env.local and fill in values (see README).

# PortlandMaps server API key (from maps@portlandoregon.gov)
PORTLANDMAPS_API_KEY=

# Dev-only: set to 1 if you hit TLS "unable to get local issuer certificate" (disables cert verification — insecure)
# PORTLANDMAPS_TLS_INSECURE=1

# HTTP server bind
HOST=127.0.0.1
PORT=3001
